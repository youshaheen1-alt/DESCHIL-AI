# ──────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────
PORT=
HOST=
NODE_ENV=
NITRO_PRESET=

# ──────────────────────────────────────────────
# Database (Railway Postgres)
# ──────────────────────────────────────────────
DATABASE_URL=

# PostgreSQL SSL mode (optional — auto-detected from DATABASE_URL by default)
#   leave empty  → no SSL for localhost, strict TLS for cloud/Railway (recommended)
#   require      → strict TLS with certificate validation (explicit)
#   no-verify    → TLS without cert validation (legacy/self-signed CAs only — avoid in prod)
#   disable      → no SSL (local dev without SSL)
PGSSL=

# ──────────────────────────────────────────────
# Sessions & admin bootstrap
# ──────────────────────────────────────────────
SESSION_SECRET=
DESCHIL_USER=
DESCHIL_PASSWORD=

# ──────────────────────────────────────────────
# Supabase (optional — if you also want to talk to a Supabase project)
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ──────────────────────────────────────────────
# AI providers (leave empty to disable)
# ──────────────────────────────────────────────
LOVABLE_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# Search / scrape / audio
EXA_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
ELEVENLABS_API_KEY=

# ──────────────────────────────────────────────
# Default AI routing
# ──────────────────────────────────────────────
DEFAULT_AI_PROVIDER=
DEFAULT_AI_MODEL=
LOG_LEVEL=

# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Required in production — set when registering the webhook with Telegram
# (pass as secret_token in setWebhook). Requests without a matching header
# are rejected 401 in production; skipped with a warning in development.
TELEGRAM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# WhatsApp — Green API
# ──────────────────────────────────────────────
GREEN_API_TOKEN=
GREEN_API_INSTANCE_ID=

# ──────────────────────────────────────────────
# WhatsApp — Meta Cloud API (alternative to Green API)
# ──────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Required in production for X-Hub-Signature-256 HMAC verification.
# Set this to the App Secret from your Meta App dashboard.
WHATSAPP_APP_SECRET=

# ──────────────────────────────────────────────
# Discord (HTTP interactions)
# ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# ──────────────────────────────────────────────
# Railway (optional — for programmatic deploys)
# ──────────────────────────────────────────────
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_ENV_ID=
