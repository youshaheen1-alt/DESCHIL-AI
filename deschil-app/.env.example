# ─────────────────────────────────────────────────────────────────────────────
# DESCHIL — Environment Variables
# Copy this file to .env for local development. Never commit .env.
# On Railway, set these in the service "Variables" tab.
# ─────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
NITRO_PRESET=node-server

# ──────────────────────────────────────────────
# Database  ★ REQUIRED
# ──────────────────────────────────────────────
# Railway Postgres: add the PostgreSQL plugin and use the provided URL.
# The app reads this automatically — no other DB config needed.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# PostgreSQL SSL mode (optional — auto-detected by default)
#
#   (unset)    → rejectUnauthorized:false for cloud URLs (correct for Railway)
#   disable    → no SSL (local dev without SSL enabled)
#   require    → strict TLS with certificate validation (needs NODE_EXTRA_CA_CERTS)
#   no-verify  → TLS without cert validation (same as unset default, explicit)
#
# Leave unset for Railway — it automatically uses rejectUnauthorized:false
# which is required because Railway Postgres uses self-signed certificates.
PGSSL=

# ──────────────────────────────────────────────
# Session security  ★ REQUIRED
# ──────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-secret

# ──────────────────────────────────────────────
# Admin bootstrap (optional but recommended)
# ──────────────────────────────────────────────
# When set, you can always sign in with these credentials regardless of
# what is in the database. The account is automatically created in the
# database with the admin role on first login.
DESCHIL_USER=admin@example.com
DESCHIL_PASSWORD=change-me-to-something-strong

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# Values: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Default AI routing
# ──────────────────────────────────────────────
# Which provider to use first when no provider is specified.
# Must match one of: lovable openai openrouter gemini anthropic groq deepseek mistral xai
DEFAULT_AI_PROVIDER=groq
DEFAULT_AI_MODEL=llama-3.1-8b-instant

# ──────────────────────────────────────────────
# AI Providers  (set at least one to enable AI commands)
# ──────────────────────────────────────────────
GROQ_API_KEY=
LOVABLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
ELEVENLABS_API_KEY=

# ──────────────────────────────────────────────
# Telegram  (optional)
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Required in production — pass as secret_token when calling setWebhook
TELEGRAM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# WhatsApp — Meta Cloud API  (optional)
# ──────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Required in production for X-Hub-Signature-256 verification
WHATSAPP_APP_SECRET=

# ──────────────────────────────────────────────
# WhatsApp — Green API  (optional alternative to Meta Cloud)
# ──────────────────────────────────────────────
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ──────────────────────────────────────────────
# Discord  (optional)
# ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
